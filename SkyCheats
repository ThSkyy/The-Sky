-- SERVICES
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- CONFIG
local PASSWORD = "ceu"

-- UTIL
local function tween(obj, props, time)
    local t = TweenService:Create(
        obj,
        TweenInfo.new(time or 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        props
    )
    t:Play()
    return t
end

local function notify(text)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(0, 280, 0, 60)
    f.Position = UDim2.new(0, 20, 0, 20)
    f.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
    f.Parent = playerGui

    local c = Instance.new("UICorner", f)
    c.CornerRadius = UDim.new(0, 12)

    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(1, 0, 1, 0)
    l.BackgroundTransparency = 1
    l.Text = text
    l.TextColor3 = Color3.new(1,1,1)
    l.TextScaled = true
    l.Font = Enum.Font.GothamBold

    tween(f, {Position = UDim2.new(0, 20, 0, 100)}, 0.25)
    Debris:AddItem(f, 2.5)
end

