-- TABS
local tabNames = {
    "Aimbot","ESP","Movement","Visuals","Combat",
    "Teleport","Config","Misc","Exploits","Performance"
}

local tabButtons = {}
local tabFrames = {}

for i,name in ipairs(tabNames) do
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0,130,0,40)
    btn.Position = UDim2.new(0,(i-1)*135,0,0)
    btn.Text = name
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamBold
    btn.BackgroundColor3 = i==1 and Color3.fromRGB(0,200,150) or Color3.fromRGB(35,35,60)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,12)

    local content = Instance.new("Frame", scroll)
    content.Size = UDim2.new(1,-20,0,300)
    content.Position = UDim2.new(0,10,0,60)
    content.Visible = i==1
    content.BackgroundTransparency = 1

    tabButtons[i] = btn
    tabFrames[i] = content

    btn.MouseButton1Click:Connect(function()
        for j=1,#tabFrames do
            tabFrames[j].Visible = false
            tabButtons[j].BackgroundColor3 = Color3.fromRGB(35,35,60)
        end
        content.Visible = true
        btn.BackgroundColor3 = Color3.fromRGB(0,200,150)
    end)
end

-- EVENTS
